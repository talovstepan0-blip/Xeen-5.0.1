```gitignore
# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Database
*.db

# Logs
*.log

# Environment
.env
.env.local
*.env.*

# Dependencies
.venv/
venv/
node_modules/

# Build artifacts
dist/
build/
target/

# Coverage
.coverage
coverage/
htmlcov/

# Editors
.vscode/
.idea/
*.swp
*.swo
*.tmp

# System
.DS_Store
Thumbs.db
```