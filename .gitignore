```gitignore
# Python compiled files
__pycache__/
*.pyc
*.pyo
*.pyd

# Database files
*.db

# Logs and temporary files
*.log
*.tmp

# Environment files
.env
.env.local
*.env.*

# Editor/IDE files
.vscode/
.idea/
*.swp
*.swo

# Coverage reports
coverage/
htmlcov/
.coverage

# Testing
.pytest_cache/
.mypy_cache/
```